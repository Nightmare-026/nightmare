generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  avatarUrl     String?  @map("avatar_url")
  isBanned      Boolean  @default(false) @map("is_banned")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  orders        Order[]
  downloadTokens DownloadToken[]
  wishlists     Wishlist[]
  productReviews ProductReview[]
  quickReactions QuickReaction[]
  siteFeedback  SiteFeedback[]

  @@map("users")
}

model Category {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  slug          String   @unique
  icon          String   @default("📚")
  description   String?
  displayOrder  Int      @default(0) @map("display_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  subjects      Subject[]
  products      Product[]

  @@map("categories")
}

model Subject {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  slug          String   @unique
  categoryId    String   @map("category_id") @db.Uuid
  description   String?
  displayOrder  Int      @default(0) @map("display_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products      Product[]

  @@map("subjects")
}

model Product {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  slug          String   @unique
  description   String   @db.Text
  categoryId    String   @map("category_id") @db.Uuid
  subjectId     String?  @map("subject_id") @db.Uuid
  type          ProductType
  price         Decimal? @db.Decimal(10, 2)
  isFree        Boolean  @default(false) @map("is_free")
  fileUrl       String   @map("file_url")
  previewUrl    String?  @map("preview_url")
  thumbnailUrl  String?  @map("thumbnail_url")
  tags          String[] @default([])
  downloadsCount Int     @default(0) @map("downloads_count")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subject       Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  orders        Order[]
  downloadTokens DownloadToken[]
  wishlists     Wishlist[]
  reviews       ProductReview[]
  quickReactions QuickReaction[]

  @@map("products")
}

enum ProductType {
  pdf
  wallpaper
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @map("user_id") @db.Uuid
  productId         String      @map("product_id") @db.Uuid
  amount            Decimal     @db.Decimal(10, 2)
  status            OrderStatus @default(pending)
  razorpayOrderId   String?     @unique @map("razorpay_order_id")
  razorpayPaymentId String?     @unique @map("razorpay_payment_id")
  razorpaySignature String?     @map("razorpay_signature")
  promoCodeId       String?     @map("promo_code_id") @db.Uuid
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  downloadTokens    DownloadToken[]

  @@map("orders")
}

enum OrderStatus {
  pending
  paid
  failed
  refunded
}

model DownloadToken {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  token           String    @unique @default(uuid()) @db.Uuid
  orderId         String?   @map("order_id") @db.Uuid
  expiresAt       DateTime  @map("expires_at")
  downloadCount   Int       @default(0) @map("download_count")
  maxDownloads    Int       @default(3) @map("max_downloads")
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  order           Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("download_tokens")
}

model Wishlist {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model ProductReview {
  id                  String   @id @default(uuid()) @db.Uuid
  productId           String   @map("product_id") @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  rating              Int
  reviewText          String?  @map("review_text") @db.Text
  isVerifiedPurchase  Boolean  @default(false) @map("is_verified_purchase")
  isApproved          Boolean  @default(true) @map("is_approved")
  helpfulCount        Int      @default(0) @map("helpful_count")
  photoUrl            String?  @map("photo_url")
  createdAt           DateTime @default(now()) @map("created_at")

  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("product_reviews")
}

model QuickReaction {
  id              String         @id @default(uuid()) @db.Uuid
  productId       String         @map("product_id") @db.Uuid
  userId          String?        @map("user_id") @db.Uuid
  reactionType    ReactionType   @map("reaction_type")
  ipAddress       String?        @map("ip_address")
  createdAt       DateTime       @default(now()) @map("created_at")

  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([productId, userId])
  @@unique([productId, ipAddress])
  @@map("quick_reactions")
}

enum ReactionType {
  fire
  premium
  creative
  useful
}

model SiteFeedback {
  id              String   @id @default(uuid()) @db.Uuid
  sectionName     String   @map("section_name")
  pageUrl         String   @map("page_url")
  rating          Int
  message         String?  @db.Text
  email           String?
  userId          String?  @map("user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("site_feedback")
}

model PromoCode {
  id              String      @id @default(uuid()) @db.Uuid
  code            String      @unique
  discountType    DiscountType @map("discount_type")
  discountValue   Decimal     @db.Decimal(10, 2) @map("discount_value")
  usageLimit      Int?        @map("usage_limit")
  usageCount      Int         @default(0) @map("usage_count")
  minOrderAmount  Decimal?    @db.Decimal(10, 2) @map("min_order_amount")
  expiresAt       DateTime?   @map("expires_at")
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")

  @@map("promo_codes")
}

enum DiscountType {
  percent
  flat
}

model EmailSubscriber {
  id              String       @id @default(uuid()) @db.Uuid
  email           String       @unique
  isActive        Boolean      @default(true) @map("is_active")
  source          SubscriberSource
  createdAt       DateTime     @default(now()) @map("created_at")

  @@map("email_subscribers")
}

enum SubscriberSource {
  footer
  popup
  checkout
}

model AdminLog {
  id              String   @id @default(uuid()) @db.Uuid
  action          String
  userEmail       String   @map("user_email")
  ipAddress       String   @map("ip_address")
  details         Json?
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("admin_logs")
}
